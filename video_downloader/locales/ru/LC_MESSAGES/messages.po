#: app.py:130
#, python-brace-format
msgid ""
"Hello, {name}! This is app for downloading any video from TikTok and "
"YouTube. Write down a url link to video for downloading!"
msgstr ""
"Привет, {name}! Это приложение для установки любых видео с TikTok и "
"YouTube. Напиши url-ссылку на видео ниже для его установки!"

#: app.py:154
#, python-brace-format
msgid ""
"We would be able to get the {count_urls} URLs from your message. We're "
"starting to download them..."
msgstr ""
"Мы смогли получить {count_urls} URL-адреса из вашего сообщения. Мы "
"начинаем их загружать..."

#: app.py:159 app.py:219
msgid "Something went wrong...We send msg to admin, try later!"
msgstr ""
"Что-то пошло не так...Мы уже отправили сообщение администратору, "
"попробуйте позже!"

#: app.py:162 app.py:222 app.py:254
#, python-brace-format
msgid ""
"Something went wrong at {error_situation} at time {date_and_time}. Check "
"logs for more information!"
msgstr ""
"Что-то пошло не так в {error_situation} во время {date_and_time}. "
"Посмотрите логи для подробной информации!"

#: app.py:190
#, python-brace-format
msgid "Video {video_id} is too big for sending back to you!"
msgstr "Видео {video_id} слишком большое, чтобы мы могли его отправить тебе!"

#: app.py:213
#, python-brace-format
msgid "{count_videos} video was downloaded!"
msgstr "{count_videos} видео было скачано!"

#: app.py:239
msgid "Sending the videos!"
msgstr "Отправляем видео!"

#: app.py:263
#, python-brace-format
msgid ""
"No urls! Nothing to download...For download write a url to video from "
"available platforms ({available_platforms})!"
msgstr ""
"Нет URL-адресов! Скачивать нечего...Для скачивания введите URL-адрес "
"видео с доступных платформ ({available_platforms})!"

#: app.py:268
msgid "For download video send a url here!"
msgstr "Отправьте url для скачивания видео!"

#~ msgid "We could get {count_urls} urls from your msg. Start downloading them..."
#~ msgstr ""

#~ msgid "Upload a videos!"
#~ msgstr ""

